# Môi trường ảo (Virtual Environment)
venv/
env/
.env

# Cache của Python
__pycache__/
*.py[cod]
*$py.class

# Thư mục chứa trọng số AI (Rất nặng, không đẩy lên Git)
models/*.bin
models/*.pt
models/*.safetensors
models/*.h5

# Thư mục dữ liệu thật (Chỉ giữ lại file rỗng hoặc file mẫu)
data/sample_cvs/*.pdf
data/sample_cvs/*.docx
!data/sample_cvs/.gitkeep

# File hệ điều hành
.DS_Store
Thumbs.db